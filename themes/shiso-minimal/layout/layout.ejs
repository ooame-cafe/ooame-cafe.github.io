<%# 全站骨架：页头导航、内容区、页脚、搜索弹窗与前端脚本入口。 %>
<!doctype html>
<html lang="<%= config.language || 'zh-CN' %>">
<head>
  <%- partial('partial/head') %>
</head>
<body>
  <a class="skip-link" href="#main">跳到正文</a>

  <header class="site-header">
    <div class="header-inner">
      <a class="brand" href="<%- url_for('/') %>" aria-label="<%= config.title %> 首页">
        <span class="brand-mark" aria-hidden="true"></span>
        <span>
          <strong><%= config.title %></strong>
          <small><%= config.subtitle %></small>
        </span>
      </a>

      <nav class="site-nav" aria-label="主导航">
        <% Object.entries(config.menu || {}).forEach(function([name, path]) { %>
          <a href="<%- url_for(path) %>"><%= name %></a>
        <% }) %>
      </nav>

      <div class="header-actions">
        <button class="icon-button" type="button" data-search-open aria-label="打开站内搜索">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m21 21-4.3-4.3m2.3-5.2a7.5 7.5 0 1 1-15 0 7.5 7.5 0 0 1 15 0Z"/></svg>
        </button>
        <button class="icon-button" type="button" data-theme-toggle aria-label="切换明暗主题">
          <svg class="theme-sun" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
          <svg class="theme-moon" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.5 15.2A8.5 8.5 0 0 1 8.8 3.5 8.5 8.5 0 1 0 20.5 15.2Z"/></svg>
        </button>
      </div>
    </div>
  </header>

  <main id="main" class="site-main">
    <%- body %>
  </main>

  <footer class="site-footer">
    <div>
      <strong><%= config.title %></strong>
      <p><%= config.profile.footer %></p>
    </div>
    <div class="footer-links">
      <% Object.entries(config.social || {}).forEach(function([name, link]) { %>
        <a href="<%- link %>" target="_blank" rel="noopener noreferrer"><%= name %></a>
      <% }) %>
      <a href="<%- url_for('/atom.xml') %>">RSS</a>
      <a href="<%- url_for('/admin/index.html') %>">写作后台</a>
    </div>
    <p class="copyright">© <%= new Date().getFullYear() %> <%= config.author %></p>
  </footer>

  <dialog class="search-dialog" data-search-dialog data-index-url="<%- url_for('/' + config.search.path) %>">
    <form method="dialog" class="search-head">
      <label for="site-search">搜索文章</label>
      <button class="text-button" value="close" aria-label="关闭搜索">关闭</button>
    </form>
    <input id="site-search" type="search" autocomplete="off" placeholder="输入标题、摘要或标签" data-search-input>
    <p class="search-status" data-search-status>输入关键词开始搜索。</p>
    <div class="search-results" data-search-results></div>
  </dialog>

  <button class="back-to-top" type="button" data-back-to-top aria-label="返回页面顶部">↑</button>
  <%- js('js/theme') %>
  <%- js('js/search') %>
  <%- js('js/article') %>
</body>
</html>
