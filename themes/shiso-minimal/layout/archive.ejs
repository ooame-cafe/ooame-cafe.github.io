<%# 归档页：按年份列出文章。 %>
<section class="page-shell">
  <header class="page-header">
    <p class="eyebrow">ARCHIVE</p>
    <h1>文章归档</h1>
    <p>按发布时间整理，共 <%= site.posts.length %> 篇公开文章。</p>
  </header>

  <div class="archive-list">
    <% var lastYear = null; %>
    <% page.posts.each(function(post) { %>
      <% var year = date(post.date, 'YYYY'); %>
      <% if (year !== lastYear) { %>
        <% lastYear = year; %>
        <h2><%= year %></h2>
      <% } %>
      <article class="archive-item">
        <time datetime="<%= date(post.date, 'YYYY-MM-DD') %>"><%= date(post.date, 'MM月DD日') %></time>
        <div>
          <a href="<%- url_for(post.path) %>"><%= post.title %></a>
          <% if (post.categories && post.categories.length) { %>
            <span><%= post.categories.first().name %></span>
          <% } %>
        </div>
      </article>
    <% }) %>
  </div>

  <% if (page.total && page.total > 1) { %>
    <nav class="pagination" aria-label="归档分页">
      <%- paginator({ prev_text: '上一页', next_text: '下一页' }) %>
    </nav>
  <% } %>
</section>
