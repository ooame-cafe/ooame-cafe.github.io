<%# 文章详情：标题信息、封面、正文、自动目录与标签。 %>
<div class="article-layout">
  <article class="article">
    <header class="article-header">
      <p class="eyebrow">ARTICLE</p>
      <h1><%= page.title %></h1>
      <div class="post-meta">
        <time datetime="<%= date(page.date, 'YYYY-MM-DD') %>"><%= date(page.date, 'YYYY年MM月DD日') %></time>
        <span>·</span>
        <span><%= reading_time(page.content) %> 分钟阅读</span>
        <% if (page.categories && page.categories.length) { %>
          <span>·</span>
          <% page.categories.each(function(category, index) { %>
            <a href="<%- url_for(category.path) %>"><%= category.name %></a><%= index + 1 < page.categories.length ? '、' : '' %>
          <% }) %>
        <% } %>
      </div>
    </header>

    <% if (page.cover) { %>
      <img class="article-cover" src="<%- url_for(page.cover) %>" alt="<%= page.title %>" loading="eager">
    <% } %>

    <div class="article-content" data-article-content>
      <%- page.content %>
    </div>

    <% if (page.tags && page.tags.length) { %>
      <footer class="article-tags">
        <span>相关标签</span>
        <div class="tag-list">
          <% page.tags.each(function(tag) { %>
            <a href="<%- url_for(tag.path) %>"># <%= tag.name %></a>
          <% }) %>
        </div>
      </footer>
    <% } %>
  </article>

  <aside class="article-toc" data-article-toc hidden>
    <p>本页目录</p>
    <nav aria-label="文章目录" data-toc-list></nav>
  </aside>
</div>
